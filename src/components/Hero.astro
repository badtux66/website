---
import cv from '../data/cv.json';

const { identity } = cv;
---

<section id="top" aria-label="Introduction" class="border-b border-line">
  <div class="mx-auto max-w-content px-5 py-16 sm:py-24">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">{identity.location}</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{identity.name}</h1>
    <p class="mt-3 text-xl text-muted">{identity.title}</p>
    <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <li>
        <a class="link" href={`mailto:${identity.email}`}>{identity.email}</a>
      </li>
      <li>
        <a class="link" href={identity.linkedin.url} rel="me noopener">{identity.linkedin.label}</a>
      </li>
    </ul>
    {
      /* TODO(USERNAME): after adding public/EKO_CV.pdf, uncomment this download link.
      <a
        class="mt-8 inline-block rounded border border-accent px-4 py-2 font-mono text-xs uppercase tracking-widest text-accent transition-colors hover:bg-accent hover:text-ink"
        href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}EKO_CV.pdf`}
        download
      >
        Download CV (PDF)
      </a>
      */
    }
  </div>
</section>
