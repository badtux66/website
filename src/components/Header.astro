---
import cv from '../data/cv.json';

const sections = [
  { href: '#summary', label: 'Summary' },
  { href: '#competencies', label: 'Competencies' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#education', label: 'Education' },
  { href: '#references', label: 'References' },
];
---

<header class="sticky top-0 z-10 border-b border-line bg-ink/95 backdrop-blur">
  <nav
    aria-label="Primary"
    class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-x-8 gap-y-2 px-5 py-4"
  >
    <a
      href="#top"
      class="font-mono text-sm font-semibold uppercase tracking-widest text-accent"
      aria-label={`${cv.identity.name} — back to top`}
    >
      {cv.identity.name}
    </a>
    <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm text-muted">
      {
        sections.map((section) => (
          <li>
            <a class="transition-colors hover:text-body" href={section.href}>
              {section.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
